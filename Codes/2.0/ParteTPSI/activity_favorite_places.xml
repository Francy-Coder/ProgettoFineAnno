<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <TextView
        android:id="@+id/txtFavTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Luoghi Preferiti"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <Button
        android:id="@+id/btnGoHome"
        android:layout_width="300dp"
        android:layout_height="80dp"
        android:text="🏠 Vai a Casa"
        android:textSize="22sp"
        android:backgroundTint="#1E88E5"
        android:textColor="#FFFFFF"
        android:contentDescription="Naviga verso casa"
        app:layout_constraintTop_toBottomOf="@id/txtFavTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>

    <Button
        android:id="@+id/btnGoWork"
        android:layout_width="300dp"
        android:layout_height="80dp"
        android:text="💼 Vai al Lavoro"
        android:textSize="22sp"
        android:backgroundTint="#43A047"
        android:textColor="#FFFFFF"
        android:contentDescription="Naviga verso il lavoro"
        app:layout_constraintTop_toBottomOf="@id/btnGoHome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <ListView
        android:id="@+id/listFavorites"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnGoWork"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
