<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_black">

    <!-- Anteprima fotocamera -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Overlay con risultato analisi -->
    <TextView
        android:id="@+id/txtObstacle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Analisi in corso..."
        android:textSize="24sp"
        android:textColor="@color/text_white"
        android:textStyle="bold"
        android:background="#AA000000"
        android:padding="16dp"
        android:gravity="center"
        android:accessibilityLiveRegion="polite"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="80dp"/>

    <!-- Pulsante torna indietro -->
    <Button
        android:id="@+id/btnBackCamera"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="Ferma Analisi"
        android:textSize="18sp"
        android:backgroundTint="@color/btn_red"
        android:textColor="@color/text_white"
        android:contentDescription="Ferma la fotocamera e torna indietro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>